NODE_ENV=development
PORT=4000

# ── Desarrollo local (MySQL) ────────────────────────────────
# Se usan estas variables cuando NO existe DATABASE_URL.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inventory_db
DB_USER=root
DB_PASSWORD=secret

# ── Producción (Render / PostgreSQL) ────────────────────────
# Si DATABASE_URL está definida, se ignoran las variables DB_* de arriba
# y se conecta a PostgreSQL con SSL. Render la inyecta automáticamente.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

JWT_SECRET=cambia_este_secreto_en_produccion
JWT_EXPIRES_IN=7d

# URL del frontend autorizado para CORS (en producción: la URL de Vercel)
CORS_ORIGIN=http://localhost:5173
